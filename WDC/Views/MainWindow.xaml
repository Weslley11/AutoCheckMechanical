<Window x:Class="WDC.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="WAU Design Check"
        Height="760"
        Width="1280"
        MinHeight="560"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource BrushPanel}"
        Foreground="{DynamicResource BrushTextPrimary}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                             CornerRadius="0"
                             GlassFrameThickness="0"
                             ResizeBorderThickness="6"
                             UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- Paleta inspirada no app WBC (MahApps.Metro, tema BaseDark + accent Steel).
             Tons de cinza (#212121/#373737/#424242/#525252) conferidos direto no
             XAML real do WBC; o azul-acinzentado do accent "Steel" e o "IndianRed"
             de erro são aproximações razoáveis, não os hex exatos do MahApps. -->
        <SolidColorBrush x:Key="BrushTitleBar" Color="#212121"/>
        <SolidColorBrush x:Key="BrushBanner" Color="#373737"/>
        <SolidColorBrush x:Key="BrushSidebar" Color="#424242"/>
        <SolidColorBrush x:Key="BrushPanel" Color="#262626"/>
        <SolidColorBrush x:Key="BrushCard" Color="#373737"/>
        <SolidColorBrush x:Key="BrushBorder" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="BrushAccentTeal" Color="#5B7A93"/>
        <SolidColorBrush x:Key="BrushAccentTealHover" Color="#7191AA"/>
        <SolidColorBrush x:Key="BrushAccentOrange" Color="#CD5C5C"/>
        <SolidColorBrush x:Key="BrushTextPrimary" Color="#D3D3D3"/>
        <SolidColorBrush x:Key="BrushTextSecondary" Color="#9A9A9A"/>
        <SolidColorBrush x:Key="BrushHoverSurface" Color="#454545"/>

        <!-- Botões da barra de título (minimizar / restaurar / fechar) -->
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushHoverSurface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Ícones da barra lateral -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushHoverSurface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccentTeal}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Linha de status clicável (SAP / SolidWorks), pra conectar ao clicar -->
        <Style x:Key="StatusRowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushHoverSurface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão de ação principal -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BrushAccentTeal}"/>
            <Setter Property="Foreground" Value="#0B1416"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushAccentTealHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário (exportar log) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource BrushAccentTeal}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccentTeal}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Barra de título customizada -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BrushTitleBar}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0,0,0,1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Grid.Column="0" Width="18" Height="18" Margin="16,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 2 L22 7 L22 17 L12 22 L2 17 L2 7 Z" Fill="{DynamicResource BrushAccentTeal}"/>
                            <Path Data="M12 2 L22 7 L12 12 L2 7 Z" Fill="White" Opacity="0.18"/>
                        </Canvas>
                    </Viewbox>

                    <TextBlock Grid.Column="1"
                               Text="AUTOCHECK MECHANICAL"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="3"
                               Name="txtUser"
                               Text="{Binding UserName}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               FontSize="12"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <Button x:Name="btnMinimize"
                                Content="&#xE921;"
                                Style="{StaticResource WindowButtonStyle}"
                                Command="{Binding MinimizeCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="btnMaximizeRestore"
                                Content="&#xE922;"
                                Style="{StaticResource WindowButtonStyle}"
                                Command="{Binding MaximizeRestoreCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="btnClose"
                                Content="&#xE8BB;"
                                Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- Banner estilo WEG -->
            <Border Grid.Row="1"
                    Background="{DynamicResource BrushBanner}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Grid.Column="0" Width="30" Height="30" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 2 L22 7 L22 17 L12 22 L2 17 L2 7 Z" Fill="{DynamicResource BrushAccentTeal}"/>
                            <Path Data="M12 2 L22 7 L12 12 L2 7 Z" Fill="White" Opacity="0.18"/>
                        </Canvas>
                    </Viewbox>

                    <TextBlock Grid.Column="1"
                               Text="AUTOCHECK MECHANICAL"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <Image Grid.Column="2"
                           Source="Assets/Images/GRID.png"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Height="43"
                           Width="208"
                           Margin="0,10"/>
                </Grid>
            </Border>

            <!-- Corpo -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Barra lateral -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BrushSidebar}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="0,0,1,0">

                    <StackPanel Margin="0,16,0,0" HorizontalAlignment="Center">
                        <Button x:Name="btnReconnect"
                                Content="&#xE72C;"
                                Style="{StaticResource SidebarButtonStyle}"
                                ToolTip="Verificar conexão com o SolidWorks"
                                Command="{Binding ReconnectCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="btnRunCheckSidebar"
                                Content="&#xE721;"
                                Style="{StaticResource SidebarButtonStyle}"
                                ToolTip="Rodar Check Drawing"
                                Command="{Binding RunCheckDrawingCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="btnHistorico"
                                Content="&#xE81C;"
                                Style="{StaticResource SidebarButtonStyle}"
                                ToolTip="Ir para o histórico de projetos"
                                Click="BtnHistorico_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="btnConfiguracoes"
                                Content="&#xE713;"
                                Style="{StaticResource SidebarButtonStyle}"
                                ToolTip="Alternar tema claro/escuro"
                                Command="{Binding ToggleThemeCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="btnChecks"
                                Content="&#xE8FD;"
                                Style="{StaticResource SidebarButtonStyle}"
                                ToolTip="Escolher quais checks executar"
                                Command="{Binding OpenChecksConfigCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Border>

                <!-- Conteúdo -->
                <Grid Grid.Column="1" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Busca de documentos no SAP (ZTPLM025 + busca por ECM via Web Service) -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource BrushCard}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,12">

                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="ECM"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource BrushPanel}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBox x:Name="txtEcm"
                                             Text="{Binding EcmText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             Foreground="{DynamicResource BrushTextPrimary}"
                                             CaretBrush="{DynamicResource BrushTextPrimary}"
                                             BorderThickness="0"
                                             Padding="8,6"
                                             ToolTip="Número da ECM no SAP"/>
                                </Border>

                                <Button Grid.Column="2"
                                        x:Name="btnSapConexao"
                                        Content="CONEXÃO SAP"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        FontSize="13"
                                        Padding="16,8"
                                        Margin="12,0,0,0"
                                        ToolTip="Conexão SAP via RFC/BAPI (SAP .NET Connector)"
                                        Command="{Binding AbrirSapConexaoCommand}"/>
                            </Grid>

                            <!-- Busca de documentos do DMS pela mesma ECM acima, via Web
                                 Service ITF_O_S_DOCUMENT_OUTPUT (SOA), com opção de versão
                                 igual ao SAP GUI (CV04N). -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="VERSÃO"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                                <RadioButton Grid.Column="1"
                                             Content="Última versão liberada"
                                             GroupName="VersaoDocumentoSap"
                                             Foreground="{DynamicResource BrushTextPrimary}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,16,0"
                                             IsChecked="{Binding BuscarUltimaVersaoLiberada}"/>

                                <RadioButton Grid.Column="2"
                                             Content="Última versão"
                                             GroupName="VersaoDocumentoSap"
                                             Foreground="{DynamicResource BrushTextPrimary}"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding BuscarUltimaVersao}"/>

                                <Button Grid.Column="4"
                                        x:Name="btnBuscarDocumentosPorEcm"
                                        Content="BUSCAR DOCUMENTOS (SAP)"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        FontSize="13"
                                        Padding="16,8"
                                        Margin="0,0,8,0"
                                        ToolTip="Busca no DMS (SOAP) os documentos vinculados à ECM acima"
                                        Command="{Binding BuscarDocumentosPorEcmCommand}"/>

                                <Button Grid.Column="5"
                                        x:Name="btnBaixarDocumentos"
                                        Content="BAIXAR DOCUMENTOS"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        FontSize="13"
                                        Padding="16,8"
                                        ToolTip="Copia pra uma pasta local o arquivo original (DMS) de cada documento na lista"
                                        Command="{Binding BaixarDocumentosCommand}"/>
                            </Grid>

                            <!-- Pasta padrão onde BAIXAR DOCUMENTOS salva os arquivos:
                                 dentro dela, cria automaticamente uma subpasta com o nome
                                 da ECM usada na busca de cada documento. -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="PASTA DE DOWNLOAD"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource BrushPanel}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBox Text="{Binding PastaDownloadDocumentos, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             Foreground="{DynamicResource BrushTextPrimary}"
                                             CaretBrush="{DynamicResource BrushTextPrimary}"
                                             BorderThickness="0"
                                             Padding="8,6"
                                             ToolTip="Pasta onde os documentos baixados são salvos (dentro de uma subpasta com o nome da ECM)"/>
                                </Border>

                                <Button Grid.Column="2"
                                        Content="..."
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        FontSize="13"
                                        Padding="12,8"
                                        Margin="8,0,0,0"
                                        ToolTip="Selecionar a pasta de download"
                                        Command="{Binding SelecionarPastaDownloadCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Card de conexão / arquivo -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource BrushCard}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,12">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="ARQUIVO ATUAL"
                                           FontSize="11"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Name="txtArquivo"
                                           Text="{Binding ArquivoAtual}"
                                           FontSize="16"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <Button Style="{StaticResource StatusRowButtonStyle}"
                                        Command="{Binding AbrirSapConexaoCommand}"
                                        ToolTip="Conexão SAP via RFC/BAPI (SAP .NET Connector) -- clique pra conectar">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Fill="{Binding SapLedBrush}"
                                                 Margin="0,0,8,0"
                                                 Name="ledSap"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="SAP"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" - "
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SapStatusText}"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   FontSize="13"
                                                   Name="txtSap"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource StatusRowButtonStyle}"
                                        Command="{Binding ReconnectCommand}"
                                        Margin="0,4,0,0"
                                        ToolTip="Verificar conexão com o SolidWorks -- clique pra conectar">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Fill="{Binding SolidWorksLedBrush}"
                                                 Margin="0,0,8,0"
                                                 Name="ledSolidWorks"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="SOLIDWORKS"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" - "
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SolidWorksStatusText}"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   FontSize="13"
                                                   Name="txtSolidWorks"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <Button Name="btnCheckDrawing"
                                Content="CHECK DRAWING"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding RunCheckDrawingCommand}"/>
                        <Button Name="btnVerificarArquivos"
                                Content="VERIFICAR ARQUIVOS..."
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="14"
                                Padding="18,10"
                                Margin="12,0,0,0"
                                Command="{Binding VerificarArquivosCommand}"/>
                    </StackPanel>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource BrushCard}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="12,10,8,8" x:Name="gridResultadosHeader">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="RESULTADOS"
                                               FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="2"
                                            Width="220"
                                            Background="{DynamicResource BrushPanel}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="&#xE721;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       Margin="8,0,4,0"
                                                       VerticalAlignment="Center"/>

                                            <TextBox Grid.Column="1"
                                                     x:Name="txtFiltro"
                                                     Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent"
                                                     Foreground="{DynamicResource BrushTextPrimary}"
                                                     CaretBrush="{DynamicResource BrushTextPrimary}"
                                                     BorderThickness="0"
                                                     Padding="0,5"
                                                     Margin="0,0,8,0"
                                                     ToolTip="Filtrar por nome do arquivo"/>
                                        </Grid>
                                    </Border>

                                    <Button Grid.Column="3"
                                            x:Name="btnExportarRelatorio"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"
                                            ToolTip="Exportar a tabela de resultados (CSV para Excel)"
                                            Command="{Binding ExportarRelatorioCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="Relatório" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="4"
                                            x:Name="btnLimparHistorico"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"
                                            ToolTip="Limpar todo o histórico salvo"
                                            Command="{Binding ClearHistoryCommand}">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    </Button>
                                </Grid>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto"
                                              Margin="8">
                                    <Grid x:Name="gridResults"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{DynamicResource BrushPanel}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="12,8,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Name="txtDetalheTitulo"
                                               Text="{Binding DetalheTitulo}"
                                               FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               VerticalAlignment="Center"/>

                                    <Button Grid.Column="1"
                                            x:Name="btnExportLog"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ExportLogCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="Exportar" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBox Name="txtLog"
                                         Text="{Binding LogText, Mode=OneWay}"
                                         Background="Transparent"
                                         Foreground="{DynamicResource BrushTextPrimary}"
                                         CaretBrush="{DynamicResource BrushTextPrimary}"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="8"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Barra de status -->
            <Border Grid.Row="3"
                    Background="{DynamicResource BrushTitleBar}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0,1,0,0">
                <TextBlock Name="txtStatus"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="16,0"/>
            </Border>

        </Grid>
    </Border>
</Window>
