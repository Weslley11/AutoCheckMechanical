<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <configSections>
        <section name="iceberg" type="Weg.Iceberg.Configuration.ConfigurationHandler, Weg.Iceberg"/>
    </configSections>
    <!-- Exigido pelo Weg.Iceberg.Infrastructure.Uddi.SoapClientFactory (usado
         em DocumentSearchService.cs): sem essa seção, ele lança
         "IcebergException: Configuration file is not found". O valor
         application="WAUQC" é o mesmo usado tanto pelo WBC quanto pelo WAU
         Factory Viewer (dois apps WAU diferentes), então parece ser uma
         identidade compartilhada entre ferramentas internas WAU da WEG, não
         exclusiva de um app: ainda não confirmado se o AutoCheck
         Mechanical é de fato autorizado a usá-la. -->
    <iceberg application="WAUQC" environment="Production"/>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
    </startup>
</configuration>