<Window x:Class="AutoCheckMechanical.ChecksConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar Checks"
        Height="440"
        Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Grid Margin="18" Name="gridRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Name="txtTitulo"
                   Text="Escolha quais verificações devem rodar no Check Drawing:"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="panelCheckers"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Name="btnCancelar"
                    Content="Cancelar"
                    Padding="16,6"
                    Margin="0,0,8,0"
                    Click="BtnCancelar_Click"/>
            <Button Name="btnSalvar"
                    Content="Salvar"
                    Padding="16,6"
                    FontWeight="Bold"
                    Click="BtnSalvar_Click"/>
        </StackPanel>
    </Grid>
</Window>
