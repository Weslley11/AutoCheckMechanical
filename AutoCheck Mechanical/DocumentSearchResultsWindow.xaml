<Window x:Class="AutoCheckMechanical.DocumentSearchResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Documentos encontrados (SAP)"
        Height="480"
        Width="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="#3B3B3B"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding StatusText}"
                   Foreground="#C9C9C9"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   FontSize="13"/>

        <Border Grid.Row="1"
                BorderBrush="#8C8C8C"
                BorderThickness="1">
            <ListView ItemsSource="{Binding Resultados}"
                      Background="#2E2E2E"
                      Foreground="White"
                      BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Documento" DisplayMemberBinding="{Binding DocumentNumber}" Width="100"/>
                        <GridViewColumn Header="Tipo" DisplayMemberBinding="{Binding Type}" Width="50"/>
                        <GridViewColumn Header="Parte" DisplayMemberBinding="{Binding Part}" Width="50"/>
                        <GridViewColumn Header="Versão" DisplayMemberBinding="{Binding Version}" Width="60"/>
                        <GridViewColumn Header="ECM" DisplayMemberBinding="{Binding ChangeNumber}" Width="90"/>
                        <GridViewColumn Header="Descrição" DisplayMemberBinding="{Binding Descricao}" Width="260"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</Window>
